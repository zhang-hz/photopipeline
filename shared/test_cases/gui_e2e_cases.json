{
  "$schema": "./schema.json",
  "title": "GUI E2E Test Cases",
  "description": "Layer 5 C# GUI FlaUI end-to-end test case definitions shared with cross-channel verification.",
  "expected_total_cases": 105,
  "cases": [
    {
      "id": "GE2E-001",
      "layer": 5,
      "name": "RawInput AutoExposure SDR Output via GUI",
      "category": "plugin",
      "description": "11-step GUI E2E: Launch app, Import I01, Navigate to Pipeline Editor, Add raw_input + tiff_encoder, Set params (auto, apply_wb=true), Run, Wait for progress, Export, Verify TIFF output.",
      "skip": false,
      "tags": ["gui_e2e", "raw_input", "single_plugin", "full_workflow"],
      "input_images": ["I01"],
      "pipeline_spec": {
        "nodes": [
          {
            "id": "n1",
            "plugin": "photopipeline.plugins.raw_input",
            "label": "Raw Input (auto)",
            "enabled": true,
            "params": {
              "raw_mode": "auto",
              "apply_white_balance": true
            }
          },
          {
            "id": "n2",
            "plugin": "photopipeline.plugins.tiff_encoder",
            "label": "TIFF Output",
            "enabled": true,
            "params": {
              "compression": "deflate",
              "pixel_format": "u8"
            }
          }
        ],
        "edges": [
          { "from": "n1", "to": "n2" }
        ]
      },
      "assertions": {
        "tolerance_per_channel": 0,
        "assertion_type": "pixel_exact",
        "expected_format": "TIFF",
        "expected_width": 1920,
        "expected_height": 1080,
        "expected_bit_depth": 8,
        "golden_reference": "golden/ge2e001_raw_auto_tiff.png"
      }
    },
    {
      "id": "GE2E-002",
