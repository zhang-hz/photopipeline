{
  "$schema": "./schema.json",
  "title": "Regression Test Cases",
  "description": "Golden-reference regression test cases. Each case has a golden_reference image that must match pixel-exact across all channels. Golden images are generated by Channel 1 (Rust Engine) and verified by all three channels.",
  "expected_total_cases": 7,
  "cases": [
    {
      "id": "REG-001",
      "layer": 6,
      "name": "RAW to sRGB to TIFF Regression Baseline",
      "category": "regression",
      "description": "Regression baseline: raw_input(auto) -> colorspace(srgb) -> tiff_encoder(deflate). Golden reference generated by Rust Engine channel; C# gRPC and GUI channels must produce pixel-identical output.",
      "skip": false,
      "tags": ["regression", "golden", "raw_workflow", "3_node", "baseline"],
      "input_images": ["I01"],
      "pipeline_spec": {
        "nodes": [
          {
            "id": "n1",
            "plugin": "photopipeline.plugins.raw_input",
            "label": "Raw Input",
            "enabled": true,
            "params": {
              "raw_mode": "auto",
              "apply_white_balance": true
            }
          },
          {
            "id": "n2",
            "plugin": "photopipeline.plugins.colorspace",
            "label": "sRGB Color Space",
            "enabled": true,
            "params": {
              "source_color_space": "srgb",
              "target_color_space": "srgb",
              "rendering_intent": "perceptual",
              "embed_icc": true
            }
          },
          {
            "id": "n3",
            "plugin": "photopipeline.plugins.tiff_encoder",
            "label": "TIFF Output",
            "enabled": true,
            "params": {
              "compression": "deflate",
              "pixel_format": "u8"
            }
          }
        ],
        "edges": [
          { "from": "n1", "to": "n2" },
          { "from": "n2", "to": "n3" }
        ]
      },
      "assertions": {
        "tolerance_per_channel": 0,
        "assertion_type": "pixel_exact",
        "expected_format": "TIFF",
        "expected_width": 1920,
        "expected_height": 1080,
        "expected_bit_depth": 8,
        "golden_reference": "golden/reg001_raw_colorspace_tiff.png"
      }
    },
    {
      "id": "REG-002",
      "layer": 6,
      "name": "Transform Crop 50% to PNG Regression Baseline",
      "category": "regression",
      "description": "Regression baseline: transform(crop 50%) -> png_encoder. Output must be 960x540 PNG with pixel-exact match to golden reference across all channels.",
      "skip": false,
      "tags": ["regression", "golden", "transform", "crop", "2_node", "baseline"],
      "input_images": ["I01"],
      "pipeline_spec": {
        "nodes": [
          {
            "id": "n1",
            "plugin": "photopipeline.plugins.transform",
            "label": "Transform (crop 50%)",
            "enabled": true,
            "params": {
              "crop_enabled": true,
              "crop_left": 25,
              "crop_top": 25,
              "crop_width": 50,
              "crop_height": 50
            }
          },
          {
            "id": "n2",
            "plugin": "photopipeline.plugins.png_encoder",
            "label": "PNG Output",
            "enabled": true,
            "params": {
              "color_type": "rgb",
              "compression_level": 6
            }
          }
        ],
        "edges": [
          { "from": "n1", "to": "n2" }
        ]
      },
      "assertions": {
        "tolerance_per_channel": 0,
        "assertion_type": "pixel_exact",
        "expected_format": "PNG",
        "expected_width": 960,
        "expected_height": 540,
        "expected_bit_depth": 8,
        "golden_reference": "golden/reg002_crop50_png.png"
      }
    }
  ]
}
