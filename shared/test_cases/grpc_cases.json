    {
      "id": "GRPC-012",
      "layer": 2,
      "name": "Linear 3-Node Pipeline RAW to TIFF via gRPC",
      "category": "pipeline",
      "description": "Verify gRPC pipeline executes a 3-node linear chain: raw_input→colorspace→tiff_encoder.",
      "skip": false,
      "tags": ["grpc", "pipeline", "linear", "3_node", "multi_plugin"],
      "input_images": ["I01"],
      "pipeline_spec": {
        "nodes": [
          {
            "id": "n1",
            "plugin": "photopipeline.plugins.raw_input",
            "label": "Raw Input",
            "enabled": true,
            "params": {
              "raw_mode": "auto",
              "apply_white_balance": true
            }
          },
          {
            "id": "n2",
            "plugin": "photopipeline.plugins.colorspace",
            "label": "Colorspace sRGB",
            "enabled": true,
            "params": {
              "source_color_space": "srgb",
              "target_color_space": "srgb",
              "rendering_intent": "perceptual"
            }
          },
          {
            "id": "n3",
            "plugin": "photopipeline.plugins.tiff_encoder",
            "label": "TIFF Output",
            "enabled": true,
            "params": {
              "compression": "deflate"
            }
          }
        ],
        "edges": [
          { "from": "n1", "to": "n2" },
          { "from": "n2", "to": "n3" }
        ]
      },
      "assertions": {
        "tolerance_per_channel": 0,
        "assertion_type": "pixel_exact",
        "expected_format": "TIFF",
        "expected_width": 1920,
        "expected_height": 1080
      }
    },
