    {
      "id": "GRPC-001",
      "layer": 2,
      "name": "PipelineService Execute Colorspace SRGB to Linear",
      "category": "plugin",
      "description": "Verify gRPC PipelineService.Execute produces correct colorspace conversion from sRGB to Linear for a single solid-color image.",
      "skip": false,
      "tags": ["grpc", "colorspace", "single_plugin", "pipeline_service"],
      "input_images": ["I01"],
      "pipeline_spec": {
        "nodes": [
          {
            "id": "cs",
            "plugin": "photopipeline.plugins.colorspace",
            "label": "Colorspace sRGB->Linear",
            "enabled": true,
            "params": {
              "source_color_space": "srgb",
              "target_color_space": "linear",
              "rendering_intent": "relative",
              "bp_comp": false
            }
          }
        ],
        "edges": []
      },
      "assertions": {
        "tolerance_per_channel": 0,
        "assertion_type": "pixel_exact",
        "expected_format": "PNG",
        "expected_width": 1920,
        "expected_height": 1080,
        "golden_reference": "golden/I01_srgb_to_linear.png"
      }
    },
    {
