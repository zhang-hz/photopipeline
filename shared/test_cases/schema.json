{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://photopipeline.dev/schemas/test-case-v1.json",
  "title": "Photopipeline Shared Test Case Definition",
  "description": "Schema v1 for shared test cases between Rust and C# test infrastructure.",
  "type": "object",
  "required": ["id", "name", "category", "pipeline_spec", "assertions"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique test case identifier",
      "pattern": "^(CCV|GE2E|GRPC|REG)-\\d{3}$"
    },
    "layer": {
      "type": "integer",
      "description": "Test layer (0=Unit, 1=Pipeline Integration, 2=gRPC E2E, 3=C# Unit, 4=C# gRPC, 5=GUI E2E, 6=Cross-Channel)",
      "enum": [0, 1, 2, 3, 4, 5, 6]
    },
    "name": {
      "type": "string",
      "description": "Human-readable test name",
      "minLength": 1,
      "maxLength": 200
    },
    "category": {
      "type": "string",
      "description": "Test category",
      "enum": ["plugin", "pipeline", "format", "batch", "regression"]
    },
    "description": {
      "type": "string",
      "description": "Detailed test description"
    },
    "skip": {
      "type": "boolean",
      "description": "If true, this test is temporarily skipped",
      "default": false
    },
    "skip_reason": {
      "type": "string",
      "description": "Reason for skipping this test"
    },
    "tags": {
      "type": "array",
      "description": "Tags for filtering and categorization",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "input_images": {
      "type": "array",
      "description": "Input image identifiers (I01-I20 from test fixtures)",
      "items": {
        "type": "string",
        "pattern": "^I(0[1-9]|1[0-9]|20)$"
      },
      "minItems": 1,
      "maxItems": 20
    },
    "pipeline_spec": {
      "type": "object",
      "description": "Pipeline specification",
      "required": ["nodes", "edges"],
      "properties": {
        "nodes": {
          "type": "array",
          "description": "Pipeline nodes",
          "items": { "$ref": "#/$defs/PipelineNode" },
          "minItems": 1,
          "maxItems": 20
        },
        "edges": {
          "type": "array",
          "description": "Pipeline edges connecting nodes",
          "items": { "$ref": "#/$defs/PipelineEdge" }
        },
        "overrides": {
          "type": "object",
          "description": "Parameter overrides for the pipeline"
        }
      }
    },
    "assertions": {
      "type": "object",
      "description": "Assertion configuration for test validation",
      "required": ["tolerance_per_channel"],
      "properties": {
        "tolerance_per_channel": {
          "type": "integer",
          "description": "Per-channel pixel value tolerance (0 = exact match)",
          "minimum": 0,
          "maximum": 255
        },
        "assertion_type": {
          "type": "string",
          "description": "Primary assertion type",
          "enum": ["pixel_exact", "psnr", "ssim", "delta_e", "mae", "file_exists", "dimensions", "format"]
        },
        "expected_format": {
          "type": "string",
          "description": "Expected output image format",
          "enum": ["PNG", "TIFF", "JPEG", "RAW", "HEIF", "JXL", "AVIF", "EXR", "BMP", "WEBP"]
        },
        "expected_width": {
          "type": "integer",
          "description": "Expected output image width",
          "minimum": 0
        },
        "expected_height": {
          "type": "integer",
          "description": "Expected output image height",
          "minimum": 0
        },
        "expected_bit_depth": {
          "type": "integer",
          "description": "Expected output bit depth",
          "enum": [8, 10, 16, 32]
        },
        "min_psnr": {
          "type": "number",
          "description": "Minimum acceptable PSNR (dB)",
          "minimum": 0
        },
        "min_ssim": {
          "type": "number",
          "description": "Minimum acceptable SSIM (0.0-1.0)",
          "minimum": 0,
          "maximum": 1
        },
        "max_delta_e": {
          "type": "number",
          "description": "Maximum acceptable Delta-E color difference",
          "minimum": 0
        },
        "max_mae": {
          "type": "number",
          "description": "Maximum acceptable Mean Absolute Error",
          "minimum": 0
        },
        "check_metadata": {
          "type": "boolean",
          "description": "Whether to validate output metadata",
          "default": false
        },
        "expect_error": {
          "type": "boolean",
          "description": "Whether the test expects an error result",
          "default": false
        },
        "expected_error_message": {
          "type": "string",
          "description": "Expected error message substring"
        },
        "golden_reference": {
          "type": "string",
          "description": "Path to golden reference image (relative to golden_dir)"
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Metadata assertions for EXIF/GPS/XMP validation",
      "properties": {
        "exif_fields": {
          "type": "object",
          "description": "Expected EXIF field values"
        },
        "xmp_fields": {
          "type": "object",
          "description": "Expected XMP field values"
        },
        "gps_latitude": {
          "type": "number",
          "description": "Expected GPS latitude",
          "minimum": -90,
          "maximum": 90
        },
        "gps_longitude": {
          "type": "number",
          "description": "Expected GPS longitude",
          "minimum": -180,
          "maximum": 180
        },
        "datetime": {
          "type": "string",
          "description": "Expected EXIF datetime string"
        }
      }
    }
  },
  "$defs": {
    "PipelineNode": {
      "type": "object",
      "description": "A node in the processing pipeline",
      "required": ["id", "plugin"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique node identifier within the pipeline",
          "minLength": 1
        },
        "plugin": {
          "type": "string",
          "description": "Plugin ID (e.g., photopipeline.plugins.colorspace)",
          "pattern": "^photopipeline\\.plugins\\.[a-z0-9_]+$"
        },
        "label": {
          "type": "string",
          "description": "Optional human-readable label"
        },
        "enabled": {
          "type": "boolean",
          "description": "Whether this node is enabled",
          "default": true
        },
        "params": {
          "type": "object",
          "description": "Plugin-specific parameters"
        }
      }
    },
    "PipelineEdge": {
      "type": "object",
      "description": "A directed edge connecting two pipeline nodes",
      "required": ["from", "to"],
      "properties": {
        "from": {
          "type": "string",
          "description": "Source node ID",
          "minLength": 1
        },
        "to": {
          "type": "string",
          "description": "Target node ID",
          "minLength": 1
        }
      }
    }
  }
}
