{
  "$schema": "./schema.json",
  "title": "Cross-Channel Verification Test Cases",
  "description": "Layer 6 CCV test cases shared between Rust gRPC, C# gRPC, and C# GUI channels.",
  "expected_total_cases": 60,
  "cases": [
    {
      "id": "CCV-001",
      "layer": 6,
      "name": "RawInput AutoExposure Cross-Channel",
      "category": "plugin",
      "description": "Verify that all three channels (Rust Engine, gRPC C#, GUI FlaUI) produce identical output for raw_input plugin with auto exposure and white balance applied, output to TIFF.",
      "skip": false,
      "tags": ["raw_input", "plugin", "auto_exposure", "cross_channel"],
      "input_images": ["I01"],
      "pipeline_spec": {
        "nodes": [
          {
            "id": "n1",
            "plugin": "photopipeline.plugins.raw_input",
            "label": "Raw Input",
            "enabled": true,
            "params": {
              "raw_mode": "auto",
              "apply_white_balance": true
            }
          },
          {
            "id": "n2",
            "plugin": "photopipeline.plugins.tiff_encoder",
            "label": "TIFF Output",
            "enabled": true,
            "params": {
              "compression": "deflate",
              "pixel_format": "u8"
            }
          }
        ],
        "edges": [
          { "from": "n1", "to": "n2" }
        ]
      },
      "assertions": {
        "tolerance_per_channel": 0,
        "assertion_type": "pixel_exact",
        "expected_format": "TIFF",
        "expected_width": 1920,
        "expected_height": 1080,
        "expected_bit_depth": 8,
        "golden_reference": "golden/ccv001_raw_auto_tiff.png"
      }
    },
