<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Photopipeline.Views.BatchPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Batch Processing"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1" ToolTip="Batch Settings"
                    Width="28" Height="28" Padding="0">
                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets"
                           FontSize="14" HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Button>
        </Grid>

        <Grid Grid.Row="1" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Queue:" VerticalAlignment="Center" Foreground="Gray" />
            <TextBlock Grid.Column="1" x:Name="QueueCountText"
                       Text="{Binding TotalItems, StringFormat='{}{0} items'}"
                       VerticalAlignment="Center" HorizontalAlignment="Right"
                       Foreground="Gray" />
        </Grid>

        <Grid Grid.Row="2" Margin="0,8,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <ProgressBar x:Name="BatchProgressBar"
                         Value="{Binding OverallProgress}" Maximum="100" MinHeight="4" />
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,2,0,0">
                <TextBlock x:Name="CompletedText" Text="{Binding CompletedItems}" />
                <TextBlock Text=" / " />
                <TextBlock x:Name="TotalText" Text="{Binding TotalItems}" />
                <TextBlock Text=" completed" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Elapsed:" Foreground="Gray" />
            <TextBlock Grid.Column="1" x:Name="ElapsedTimeText"
                       Text="{Binding ElapsedTime}" HorizontalAlignment="Right" />
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Remaining:"
                       Foreground="Gray" Margin="0,2,0,0" />
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="RemainingTimeText"
                       Text="{Binding EstimatedRemaining}" HorizontalAlignment="Right"
                       Margin="0,2,0,0" />
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,12,0,0">
            <Button x:Name="StartButton" Style="{StaticResource AccentButtonStyle}"
                    Margin="0,0,6,0" Padding="10,6"
                    Command="{Binding StartBatchCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets"
                               FontSize="14" VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <TextBlock Text="Start" />
                </StackPanel>
            </Button>
            <Button x:Name="PauseButton" Padding="10,6" Margin="0,0,6,0"
                    Command="{Binding PauseBatchCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE769;" FontFamily="Segoe MDL2 Assets"
                               FontSize="14" VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <TextBlock Text="Pause" />
                </StackPanel>
            </Button>
            <Button x:Name="StopButton" Padding="10,6"
                    Command="{Binding StopBatchCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets"
                               FontSize="14" VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <TextBlock Text="Stop" />
                </StackPanel>
            </Button>
        </StackPanel>

        <Grid Grid.Row="5" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Output:" VerticalAlignment="Center"
                       Foreground="Gray" />
            <ComboBox Grid.Column="2" x:Name="FormatComboBox"
                      ItemsSource="{Binding OutputFormats}"
                      SelectedItem="{Binding SelectedOutputFormat}"
                      MinWidth="80"
                      ToolTip="Output file format" />
        </Grid>
    </Grid>
</UserControl>
