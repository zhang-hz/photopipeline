<UserControl x:Class="Photopipeline.Views.FilmstripView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:models="clr-namespace:Photopipeline.Models"
             xmlns:converters="clr-namespace:Photopipeline.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=ViewModels.FilmstripViewModel}">

    <UserControl.Resources>
        <converters:ByteArrayToBitmapSourceConverter x:Key="BytesToImage" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,8,8,0">
            <ui:Button Content="Import" Command="{Binding AddImagesCommand}"
                       Icon="{ui:SymbolIcon Image24}" Margin="0,0,4,0" FontSize="11" />
            <ui:Button Content="Clear" Command="{Binding ClearImagesCommand}"
                       Icon="{ui:SymbolIcon Delete24}" Appearance="Secondary" FontSize="11" Margin="0,0,4,0" />
            <ui:Button Content="To Batch" Command="{Binding SendToBatchCommand}"
                       Icon="{ui:SymbolIcon ArrowExport24}" Appearance="Secondary" FontSize="11" />
        </StackPanel>

        <!-- Sort + Thumbnail size -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="8,6,8,0">
            <TextBlock Text="Sort:" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <ComboBox ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SortBy}"
                      Width="80" FontSize="11" Margin="0,0,8,0" />
            <TextBlock Text="Size:" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <ui:Button Content="S" Width="28" Height="22" FontSize="10" Padding="0"
                       Command="{Binding SetThumbnailSizeCommand}" CommandParameter="80"
                       Appearance="Secondary" Margin="0,0,2,0" />
            <ui:Button Content="M" Width="28" Height="22" FontSize="10" Padding="0"
                       Command="{Binding SetThumbnailSizeCommand}" CommandParameter="120"
                       Appearance="Secondary" Margin="0,0,2,0" />
            <ui:Button Content="L" Width="28" Height="22" FontSize="10" Padding="0"
                       Command="{Binding SetThumbnailSizeCommand}" CommandParameter="180"
                       Appearance="Secondary" />
        </StackPanel>

        <!-- Image List -->
        <ListBox Grid.Row="2" x:Name="ImageListBox"
                 ItemsSource="{Binding FilteredImages}"
                 SelectedItem="{Binding SelectedImage}"
                 SelectionMode="Extended"
                 VirtualizingStackPanel.IsVirtualizing="True"
                 VirtualizingStackPanel.ScrollUnit="Pixel"
                 Background="Transparent" BorderThickness="0"
                 SelectionChanged="OnImageListSelectionChanged">
            <ListBox.ContextMenu>
                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                    <MenuItem Header="Open in Explorer" Command="{Binding OpenInExplorerCommand}"
                              CommandParameter="{Binding SelectedImage}" />
                    <MenuItem Header="Copy Path" Command="{Binding CopyPathCommand}"
                              CommandParameter="{Binding SelectedImage}" />
                    <Separator />
                    <MenuItem Header="Select All" Command="{Binding SelectAllCommand}" />
                    <MenuItem Header="Clear Selection" Command="{Binding ClearSelectionCommand}" />
                    <MenuItem Header="Invert Selection" Command="{Binding InvertSelectionCommand}" />
                    <Separator />
                    <MenuItem Header="Remove" Command="{Binding RemoveImageCommand}"
                              CommandParameter="{Binding SelectedImage}" />
                    <MenuItem Header="Send to Batch" Command="{Binding SendToBatchCommand}" />
                </ContextMenu>
            </ListBox.ContextMenu>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:ImageEntry}">
                    <Border Padding="6,4" Margin="4,2" CornerRadius="4"
                            Background="{DynamicResource ControlFillColorSecondaryBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Thumbnail -->
                            <Border Grid.Column="0" Width="52" Height="38" CornerRadius="3"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    ClipToBounds="True">
                                <Image Source="{Binding ThumbnailData, Converter={StaticResource BytesToImage}}"
                                       Stretch="UniformToFill" Width="52" Height="38" />
                            </Border>

                            <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding FileName}" FontSize="12"
                                           TextTrimming="CharacterEllipsis" MaxWidth="180" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontSize="10"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                        <Run Text="{Binding Width, Mode=OneWay}" /><Run Text="x" />
                                        <Run Text="{Binding Height, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock Text="{Binding Format}" FontSize="10" Margin="8,0,0,0"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Filter bar -->
        <Grid Grid.Row="3" Margin="8,4,8,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Filter images..." ClearButtonEnabled="True" Margin="0,0,4,0" />
            <ComboBox Grid.Column="1" ItemsSource="{Binding FormatFilters}"
                      SelectedItem="{Binding FilterFormat}" Width="80" FontSize="11" />
        </Grid>
    </Grid>
</UserControl>
