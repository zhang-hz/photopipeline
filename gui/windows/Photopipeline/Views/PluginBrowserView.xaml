<UserControl x:Class="Photopipeline.Views.PluginBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:models="clr-namespace:Photopipeline.Models"
             xmlns:converters="clr-namespace:Photopipeline.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=ViewModels.PluginBrowserViewModel}">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Search + Filter -->
        <StackPanel Grid.Row="0" Margin="8,8,8,4">
            <ui:TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Search plugins..." ClearButtonEnabled="True" Margin="0,0,0,4" />
            <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}"
                      FontSize="11" />
        </StackPanel>

        <!-- Plugin List -->
        <ListBox Grid.Row="1" ItemsSource="{Binding FilteredPlugins}"
                 SelectedItem="{Binding SelectedPlugin}"
                 VirtualizingPanel.ScrollUnit="Pixel"
                 Background="Transparent" BorderThickness="0"
                 PreviewMouseMove="OnPluginListMouseMove"
                 SelectionChanged="OnPluginSelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:PluginInfo}">
                    <Border Padding="6" Margin="4,2" CornerRadius="4"
                            Background="{DynamicResource ControlFillColorSecondaryBrush}" Cursor="Hand">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Version, StringFormat=v{0}}" FontSize="9" Margin="6,2,0,0"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                            <TextBlock Text="{Binding Description}" FontSize="10" TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0" />
                            <Border Margin="0,4,0,0" Padding="4,2" CornerRadius="2"
                                    Background="{DynamicResource AccentFillColorDisabledBrush}" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding Category}" FontSize="9"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </Border>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Parameter Editing Panel (shown when plugin selected) -->
        <Border Grid.Row="2" Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0"
                Visibility="{Binding SelectedPlugin, Converter={StaticResource NullToVisibility}}">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Parameters" FontSize="12" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SelectedPlugin.Name, StringFormat= - {0}}" FontSize="11"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="4,0,0,0" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="200">
                    <StackPanel x:Name="PluginParamPanel" />
                </ScrollViewer>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                    <ui:Button Content="Reset to Defaults" Appearance="Secondary" FontSize="11"
                               Margin="0,0,6,0" Click="OnResetParameters" />
                    <ui:Button Content="Add to Pipeline" Command="{Binding AddToPipelineCommand}"
                               CommandParameter="{Binding SelectedPlugin}" FontSize="11" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
