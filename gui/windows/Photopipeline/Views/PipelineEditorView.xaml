<UserControl x:Class="Photopipeline.Views.PipelineEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:Photopipeline.Controls"
             xmlns:converters="clr-namespace:Photopipeline.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=ViewModels.PipelineEditorViewModel}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Padding="4"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <ui:Button Content="New" Command="{Binding CreateCommand}" Margin="0,0,2,0" FontSize="11" />
                <ui:Button Content="Validate" Command="{Binding ValidateCommand}" Margin="0,0,2,0" FontSize="11" />

                <Separator Style="{StaticResource Separator}" Margin="4,2" />

                <!-- Execute / Cancel -->
                <ui:Button x:Name="ExecuteBtn" Content="Run" Command="{Binding ExecuteCommand}"
                           Margin="0,0,2,0" FontSize="11" />
                <ui:Button Content="Cancel" Command="{Binding CancelExecuteCommand}"
                           Margin="0,0,2,0" FontSize="11" Appearance="Transparent"
                           Visibility="{Binding IsExecuting, Converter={StaticResource BoolToVisibility}}" />

                <Separator Style="{StaticResource Separator}" Margin="4,2" />

                <ui:Button Icon="{ui:SymbolIcon ZoomIn24}" ToolTip="Zoom In"
                           Command="{Binding ZoomCanvasCommand}" CommandParameter="0.2"
                           Margin="0,0,2,0" Appearance="Transparent" />
                <ui:Button Icon="{ui:SymbolIcon ZoomOut24}" ToolTip="Zoom Out"
                           Command="{Binding ZoomCanvasCommand}" CommandParameter="-0.2"
                           Margin="0,0,2,0" Appearance="Transparent" />
                <ui:Button Content="{Binding Scale, StringFormat={}{0:F1}x}"
                           Command="{Binding ResetCanvasCommand}"
                           Appearance="Transparent" FontSize="11" Width="44" ToolTip="Reset view" />
                <ui:Button Content="Fit" Command="{Binding ResetCanvasCommand}"
                           Appearance="Transparent" FontSize="11" Width="36" />
            </StackPanel>
        </Border>

        <!-- DAG Canvas -->
        <controls:SkiaDAGCanvas Grid.Row="1" Grid.Column="0" x:Name="DAGCanvas"
            Nodes="{Binding Nodes}"
            Edges="{Binding Edges}"
            SelectedNode="{Binding SelectedNode}"
            Scale="{Binding Scale, Mode=TwoWay}"
            OffsetX="{Binding OffsetX, Mode=TwoWay}"
            OffsetY="{Binding OffsetY, Mode=TwoWay}"
            NodeDropped="OnNodeDropped"
            NodeSelected="OnNodeSelected"
            PortsConnected="OnPortsConnected"
            NodeMoved="OnNodeMoved" />

        <!-- Property panel (shown when a node is selected) -->
        <Border Grid.Row="1" Grid.Column="1" Width="240"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1,0,0,0"
                Visibility="{Binding SelectedNode, Converter={StaticResource NullToVisibility}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">
                    <TextBlock FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8">
                        <Run Text="Node: " />
                        <Run Text="{Binding SelectedNode.Label}" />
                    </TextBlock>
                    <TextBlock Text="{Binding SelectedNode.PluginId}" FontSize="10"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8" />

                    <!-- Parameters section -->
                    <TextBlock Text="Parameters" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <StackPanel x:Name="ParameterPanel" />

                    <Separator Margin="0,12" />

                    <ui:Button Content="Remove Node" Command="{Binding RemoveNodeCommand}"
                               CommandParameter="{Binding SelectedNode}" Appearance="Danger"
                               HorizontalAlignment="Stretch" FontSize="11" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Padding="8,4"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding ValidationMessage}" FontSize="11"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding ExecutionStatus}" FontSize="11"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,4,0" />
                    <ui:ProgressRing Width="14" Height="14" IsIndeterminate="True"
                                    Visibility="{Binding IsExecuting, Converter={StaticResource BoolToVisibility}}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
