<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Photopipeline.Views.PipelineEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Photopipeline.Controls">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ToolBar Grid.Row="0" Background="Transparent">
            <Button x:Name="AddNodeBtn" ToolTip="Add a plugin node"
                    Click="OnAddNodeClick">
                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
            </Button>
            <Button x:Name="DeleteBtn" ToolTip="Remove selected node"
                    Command="{Binding RemoveNodeCommand}"
                    CommandParameter="{Binding SelectedNode}">
                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
            </Button>
            <Button x:Name="DuplicateBtn" ToolTip="Duplicate selected node"
                    Command="{Binding DuplicateSelectedCommand}">
                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
            </Button>
            <Separator />
            <Button ToolTip="Zoom In"
                    Command="{Binding ZoomInCommand}">
                <TextBlock Text="&#xE8A3;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
            </Button>
            <Button ToolTip="Zoom Out"
                    Command="{Binding ZoomOutCommand}">
                <TextBlock Text="&#xE71F;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
            </Button>
            <Button ToolTip="Fit all nodes in view"
                    Command="{Binding FitAllCommand}">
                <TextBlock Text="&#xE8A3;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
            </Button>
            <Separator />
            <Button x:Name="ValidateBtn" ToolTip="Validate pipeline connections"
                    Command="{Binding ValidatePipelineCommand}">
                <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
            </Button>
        </ToolBar>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="8"
                    Background="#1A1A2E" MinWidth="800" MinHeight="400">
                <Grid x:Name="CanvasRoot">
                    <controls:SkiaDAGCanvas x:Name="DagCanvas" />
                </Grid>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
