<ui:FluentWindow x:Class="Photopipeline.Views.SettingsDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             Title="Settings" Width="520" Height="440"
             WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
             d:DataContext="{d:DesignInstance Type=ViewModels.SettingsViewModel}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <!-- General Tab -->
            <TabItem Header="General">
                <StackPanel Margin="16" MaxWidth="360">
                    <TextBlock Text="Theme" FontSize="11" Margin="0,0,0,4"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ComboBox ItemsSource="{Binding Themes}" SelectedItem="{Binding Theme}"
                              FontSize="12" Margin="0,0,0,12" />

                    <TextBlock Text="Max Recent Files" FontSize="11" Margin="0,0,0,4"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ui:NumberBox Value="{Binding MaxRecentFiles}" Minimum="5" Maximum="50" Margin="0,0,0,12" />
                </StackPanel>
            </TabItem>

            <!-- Backend Tab -->
            <TabItem Header="Backend">
                <StackPanel Margin="16" MaxWidth="360">
                    <TextBlock Text="Server Path" FontSize="11" Margin="0,0,0,4"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0" Text="{Binding ServerPath, UpdateSourceTrigger=LostFocus}"
                                    FontSize="12" Margin="0,0,4,0" />
                        <ui:Button Grid.Column="1" Content="..." Command="{Binding BrowseServerPathCommand}"
                                   Width="32" Padding="0" FontSize="14" />
                    </Grid>

                    <TextBlock Text="Port" FontSize="11" Margin="0,0,0,4"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ui:NumberBox Value="{Binding ServerPort}" Minimum="1024" Maximum="65535" Margin="0,0,0,12" />

                    <ui:ToggleSwitch IsChecked="{Binding AutoStartServer}" Margin="0,0,0,12">
                        <TextBlock Text="Auto-start backend server" FontSize="12" />
                    </ui:ToggleSwitch>
                </StackPanel>
            </TabItem>

            <!-- Output Tab -->
            <TabItem Header="Output">
                <StackPanel Margin="16" MaxWidth="360">
                    <TextBlock Text="Default Format" FontSize="11" Margin="0,0,0,4"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ComboBox ItemsSource="{Binding OutputFormats}" SelectedItem="{Binding DefaultOutputFormat}"
                              FontSize="12" Margin="0,0,0,12" />

                    <TextBlock Text="Default Output Directory" FontSize="11" Margin="0,0,0,4"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0" Text="{Binding DefaultOutputDirectory, UpdateSourceTrigger=LostFocus}"
                                    FontSize="12" Margin="0,0,4,0" />
                        <ui:Button Grid.Column="1" Content="..." Command="{Binding BrowseOutputDirectoryCommand}"
                                   Width="32" Padding="0" FontSize="14" />
                    </Grid>

                    <TextBlock Text="JPEG Quality" FontSize="11" Margin="0,0,0,4"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Slider Value="{Binding JpegQuality}" Minimum="0" Maximum="100" Width="160" />
                        <TextBlock Text="{Binding JpegQuality, StringFormat={}{0}%}" FontSize="12"
                                   VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>

                    <ui:ToggleSwitch IsChecked="{Binding EmbedMetadata}" Margin="0,0,0,12">
                        <TextBlock Text="Embed metadata (EXIF/XMP)" FontSize="12" />
                    </ui:ToggleSwitch>

                    <TextBlock Text="Thumbnail Size" FontSize="11" Margin="0,0,0,4"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ui:NumberBox Value="{Binding ThumbnailSize}" Minimum="64" Maximum="512" Margin="0,0,0,12" />
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <ui:Button x:Name="CancelBtn" Content="Cancel" Appearance="Secondary"
                       Margin="0,0,8,0" FontSize="12" Width="80" />
            <ui:Button x:Name="ResetBtn" Content="Reset" Appearance="Secondary"
                       Margin="0,0,8,0" FontSize="12" Width="80" />
            <ui:Button x:Name="SaveBtn" Content="Save" Appearance="Accent"
                       FontSize="12" Width="80" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
