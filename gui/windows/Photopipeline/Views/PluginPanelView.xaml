<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Photopipeline.Views.PluginPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Plugin Settings"
                   Style="{StaticResource SubtitleTextBlockStyle}"
                   Margin="8,8,8,4" />

        <ComboBox Grid.Row="1" x:Name="PluginSearchBox"
                  IsEditable="True" IsTextSearchEnabled="True"
                  Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                  Margin="8,0,8,8" />

        <Grid Grid.Row="2">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="PluginListPanel"
                              ItemsSource="{Binding FilteredPlugins}"
                              Margin="8,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,6" Margin="0,1" CornerRadius="4"
                                    Background="Transparent"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="OnPluginClicked">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                               FontSize="13" />
                                    <TextBlock Text="{Binding Category}" Foreground="Gray"
                                               FontSize="11" />
                                    <TextBlock Text="{Binding Description}" Foreground="#666"
                                               FontSize="10" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            <TextBlock x:Name="NoPluginText"
                       Text="No plugin selected"
                       Foreground="Gray"
                       AutomationProperties.AutomationId="NoPluginText"
                       Margin="0,20,0,0"
                       HorizontalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FilteredPlugins.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <StackPanel Grid.Row="3" Margin="8,8,8,12">
            <Button x:Name="ApplyButton"
                    Content="Apply Parameters"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Command="{Binding ApplyParametersCommand}"
                    Margin="0,0,0,8" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ResetButton" Content="Reset"
                        Margin="0,0,8,0" Padding="8,4"
                        Command="{Binding ResetParametersCommand}" />
                <Button x:Name="PreviewButton" Content="Preview"
                        Padding="8,4"
                        Visibility="Collapsed" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
