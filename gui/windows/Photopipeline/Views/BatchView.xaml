<UserControl x:Class="Photopipeline.Views.BatchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:models="clr-namespace:Photopipeline.Models"
             xmlns:converters="clr-namespace:Photopipeline.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=ViewModels.BatchViewModel}">

    <!-- Converters registered in App.xaml -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Controls -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,8,8,4">
            <ui:Button Content="Start" Command="{Binding StartBatchCommand}"
                       Icon="{ui:SymbolIcon Play24}" Margin="0,0,4,0" FontSize="11" />
            <ui:Button Content="Pause" Command="{Binding PauseBatchCommand}"
                       Icon="{ui:SymbolIcon Pause24}" Margin="0,0,4,0" Appearance="Secondary" FontSize="11" />
            <ui:Button Content="Resume" Command="{Binding ResumeBatchCommand}"
                       Icon="{ui:SymbolIcon PlayCircle24}" Margin="0,0,4,0" Appearance="Secondary" FontSize="11"
                       Visibility="{Binding IsPaused, Converter={StaticResource BoolToVisibility}}" />
            <ui:Button Content="Stop" Command="{Binding StopBatchCommand}"
                       Icon="{ui:SymbolIcon Stop24}" Margin="0,0,4,0" Appearance="Secondary" FontSize="11" />
            <ui:Button Content="Clear Done" Command="{Binding ClearCompletedCommand}"
                       Appearance="Transparent" FontSize="11" />
            <!-- Speed info -->
            <TextBlock Text="{Binding SpeedInfo}" FontSize="11" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="12,0,0,0" />
        </StackPanel>

        <!-- Queue List -->
        <ListBox Grid.Row="1" ItemsSource="{Binding BatchQueue}"
                 Background="Transparent" BorderThickness="0" Margin="8,0"
                 AllowDrop="True" Drop="OnItemDrop">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:ImageEntry}">
                    <Border Padding="6,4" Margin="2,2" CornerRadius="4"
                            Background="{DynamicResource ControlFillColorSecondaryBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Status dot -->
                            <Ellipse Grid.Column="0" Width="8" Height="8" Margin="0,0,8,0"
                                     VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="None">
                                                <Setter Property="Fill" Value="Gray" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Overridden">
                                                <Setter Property="Fill" Value="LimeGreen" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Error">
                                                <Setter Property="Fill" Value="Red" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>

                            <!-- File info -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding FileName}" FontSize="11"
                                           TextTrimming="CharacterEllipsis" MaxWidth="200" />
                                <TextBlock FontSize="9" Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                                    <Run Text="{Binding Width, Mode=OneWay}" /><Run Text="x" />
                                    <Run Text="{Binding Height, Mode=OneWay}" /><Run Text=" " />
                                    <Run Text="{Binding Format, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>

                            <!-- Status text -->
                            <TextBlock Grid.Column="2" FontSize="10" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="None">
                                                <Setter Property="Text" Value="Queued" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Overridden">
                                                <Setter Property="Text" Value="Done" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Error">
                                                <Setter Property="Text" Value="Failed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Overall Progress -->
        <Grid Grid.Row="2" Margin="8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <ProgressBar Value="{Binding OverallProgress}" Maximum="100" Height="6" Margin="0,0,8,0" />
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                        <Run Text="{Binding CompletedItems, Mode=OneWay}" /><Run Text=" done, " />
                        <Run Text="{Binding FailedItems, Mode=OneWay}" /><Run Text=" failed, " />
                        <Run Text="{Binding TotalItems, Mode=OneWay}" /><Run Text=" total" />
                    </TextBlock>
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                <TextBlock Text="{Binding ElapsedTime}" FontSize="11" HorizontalAlignment="Right"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <TextBlock Text="{Binding EstimatedRemaining}" FontSize="10" HorizontalAlignment="Right"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
            </StackPanel>
        </Grid>

        <!-- Output Settings -->
        <Border Grid.Row="3" Padding="8" Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <StackPanel>
                <TextBlock Text="Output Settings" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Directory:" FontSize="11"
                               VerticalAlignment="Center" Width="64" />
                    <ui:TextBox Grid.Row="0" Grid.Column="1" Text="{Binding OutputDirectory, UpdateSourceTrigger=LostFocus}"
                                PlaceholderText="Select output directory..." FontSize="11" Margin="0,2,4,2" />
                    <ui:Button Grid.Row="0" Grid.Column="2" Content="..."
                               Command="{Binding BrowseOutputDirectoryCommand}"
                               Width="32" Padding="0" FontSize="14" Margin="0,2" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Template:" FontSize="11"
                               VerticalAlignment="Center" Width="64" />
                    <ui:TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                Text="{Binding FileNameTemplate, UpdateSourceTrigger=PropertyChanged}"
                                FontSize="11" Margin="0,2" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Format:" FontSize="11"
                               VerticalAlignment="Center" Width="64" />
                    <ComboBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                              ItemsSource="{Binding OutputFormats}" SelectedItem="{Binding SelectedOutputFormat}"
                              FontSize="11" Margin="0,2" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Quality:" FontSize="11"
                               VerticalAlignment="Center" Width="64" />
                    <StackPanel Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,2">
                        <Slider Value="{Binding JpegQuality}" Minimum="0" Maximum="100" Width="120" />
                        <TextBlock Text="{Binding JpegQuality, StringFormat={}{0}%}" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,0,0" Width="36" />
                    </StackPanel>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Parallel:" FontSize="11"
                               VerticalAlignment="Center" Width="64" />
                    <ui:NumberBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                                  Value="{Binding ParallelCount}" Minimum="1" Maximum="32" Margin="0,2" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
