<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Photopipeline.Views.PreviewView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Photopipeline.Controls">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ToolBar -->
        <ToolBar Grid.Row="0" Background="Transparent">
            <Button ToolTip="Zoom In"
                    Command="{Binding ZoomInCommand}">
                <TextBlock Text="&#xE8A3;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
            </Button>
            <Button ToolTip="Zoom Out"
                    Command="{Binding ZoomOutCommand}">
                <TextBlock Text="&#xE71F;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
            </Button>
            <Separator />
            <ToggleButton x:Name="SplitViewBtn" ToolTip="Split View"
                          IsChecked="{Binding IsSplitView}">
                <TextBlock Text="&#xE890;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
            </ToggleButton>
            <ToggleButton x:Name="SideBySideBtn" ToolTip="Side by Side"
                          IsChecked="{Binding IsSideBySide}">
                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
            </ToggleButton>
            <Separator />
            <Button ToolTip="Fit"
                    Command="{Binding FitToWindowCommand}">
                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
            </Button>
            <Button ToolTip="1:1"
                    Command="{Binding ResetZoomCommand}">
                <TextBlock Text="&#xE8A3;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
            </Button>
            <Separator />
            <Button ToolTip="Export"
                    Command="{Binding ExportImageCommand}">
                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
            </Button>
        </ToolBar>

        <Border Grid.Row="1" Margin="4"
                BorderBrush="Gray" BorderThickness="1" CornerRadius="8"
                Background="#F8F8F8">
            <Grid x:Name="PreviewContainer">
                <controls:BeforeAfterView x:Name="BeforeAfterControl"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch" />

                <StackPanel x:Name="NoPreviewPanel"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="&#xE8B9;" FontFamily="Segoe MDL2 Assets"
                               FontSize="48" Foreground="#888"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="No image selected"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               Foreground="#888" Margin="0,8,0,0"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Select an image from the filmstrip to preview"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="#AAA"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Grid Grid.Row="2" Margin="8,2" Height="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Before"
                       FontSize="11" VerticalAlignment="Center"
                       Foreground="Gray" />
            <TextBlock Grid.Column="2" Text="After"
                       FontSize="11" VerticalAlignment="Center"
                       Foreground="Gray" Margin="16,0,0,0" />
        </Grid>
    </Grid>
</UserControl>
