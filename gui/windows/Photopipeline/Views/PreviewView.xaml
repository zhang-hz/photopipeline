<UserControl x:Class="Photopipeline.Views.PreviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:Photopipeline.Controls"
             xmlns:converters="clr-namespace:Photopipeline.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=ViewModels.PreviewViewModel}">

    <!-- Converters registered in App.xaml -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Padding="4" Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <ui:Button Icon="{ui:SymbolIcon ZoomIn24}" ToolTip="Zoom In"
                           Command="{Binding ZoomInCommand}" Margin="0,0,2,0" Appearance="Transparent" />
                <ui:Button Icon="{ui:SymbolIcon ZoomOut24}" ToolTip="Zoom Out"
                           Command="{Binding ZoomOutCommand}" Margin="0,0,2,0" Appearance="Transparent" />
                <ui:Button Content="{Binding FitLabel}" Command="{Binding FitToWindowCommand}"
                           Margin="0,0,2,0" Appearance="Transparent" FontSize="11" Width="36" />
                <ui:Button Content="1:1" Command="{Binding OneToOneCommand}"
                           Margin="0,0,2,0" Appearance="Transparent" FontSize="11" Width="36" />

                <Separator Margin="4,2" />

                <ui:Button Content="{Binding ZoomLevel, StringFormat={}{0:P0}}"
                           Command="{Binding ResetZoomCommand}" Appearance="Transparent"
                           FontSize="11" Width="50" ToolTip="Click to reset zoom" />

                <Separator Margin="4,2" />

                <ui:Button Content="Split" Command="{Binding ToggleSplitCommand}"
                           Appearance="Transparent" FontSize="11" Width="44" />
                <ui:Button AutomationProperties.AutomationId="ExportButton"
                           Content="Export" Command="{Binding ExportCommand}"
                           Appearance="Transparent" FontSize="11" Width="52" />
            </StackPanel>
        </Border>

        <!-- SkiaSharp Preview Canvas -->
        <controls:SkiaPreviewCanvas Grid.Row="1" x:Name="PreviewCanvas"
            BeforeBitmap="{Binding BeforeBitmap}"
            AfterBitmap="{Binding AfterBitmap}"
            ZoomLevel="{Binding ZoomLevel, Mode=TwoWay}"
            SplitPosition="{Binding SplitPosition}"
            IsSplitView="{Binding IsSplitView}"
            IsFitToWindow="{Binding IsFitToWindow}"
            PanOffset="{Binding PanOffset, Mode=TwoWay}"
            PixelInfoChanged="OnPixelInfoChanged" />

        <!-- Status bar: pixel info + loading indicator -->
        <Border Grid.Row="2" Padding="6,2" Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding PixelInfo}" FontSize="12" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                    <ui:ProgressRing Width="16" Height="16" IsIndeterminate="True" Margin="0,0,6,0" />
                    <TextBlock Text="Loading..." FontSize="12" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
