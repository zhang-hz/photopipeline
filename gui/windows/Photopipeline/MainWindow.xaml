<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Photopipeline.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:Photopipeline.Views"
    Title="Photopipeline" Height="720" Width="1280"
    WindowStartupLocation="CenterScreen"
    Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" MinWidth="200" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" MinWidth="400" />
        </Grid.ColumnDefinitions>

        <!-- Left Panel: TabControl for sub-panels -->
        <TabControl Grid.Column="0" Margin="4" TabStripPlacement="Top">
            <TabItem Header="Images">
                <views:FilmstripView DataContext="{Binding}" />
            </TabItem>
            <TabItem Header="Plugins">
                <views:PluginPanelView DataContext="{Binding PluginPanel}" />
            </TabItem>
            <TabItem Header="Batch">
                <views:BatchPanelView DataContext="{Binding Batch}" />
            </TabItem>
        </TabControl>

        <GridSplitter Grid.Column="1" Width="5"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" />

        <!-- Right Panel -->
        <Grid Grid.Column="2" Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="200" />
                <RowDefinition Height="5" />
                <RowDefinition Height="*" MinHeight="150" />
            </Grid.RowDefinitions>

            <!-- Image Preview -->
            <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1"
                    CornerRadius="4" Background="#F0F0F0">
                <views:PreviewView DataContext="{Binding}" />
            </Border>

            <GridSplitter Grid.Row="1" Height="5"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" />

            <!-- Pipeline Editor -->
            <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1"
                    CornerRadius="4" Background="#F0F0F0">
                <views:PipelineEditorView DataContext="{Binding PipelineEditor}" />
            </Border>
        </Grid>
    </Grid>
</Window>
