<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Photopipeline.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:Photopipeline.Views"
    xmlns:controls="using:Photopipeline.Controls"
    mc:Ignorable="d"
    Title="Photopipeline"
    Width="1400"
    Height="900"
    ExtendsContentIntoTitleBar="True"
    SystemBackdrop="Mica"
    Activated="OnWindowActivated">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="32"
              Canvas.ZIndex="1" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Photopipeline"
                       VerticalAlignment="Center" Margin="12,0,0,0"
                       FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,188,0">
                <Button x:Name="FileMenuButton" Content="File" Style="{StaticResource NavigationViewItemButtonStyle}" />
                <Button x:Name="EditMenuButton" Content="Edit" Style="{StaticResource NavigationViewItemButtonStyle}" />
                <Button x:Name="ViewMenuButton" Content="View" Style="{StaticResource NavigationViewItemButtonStyle}" />
                <Button x:Name="HelpMenuButton" Content="Help" Style="{StaticResource NavigationViewItemButtonStyle}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Filmstrip + Batch -->
            <Grid Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <ScrollViewer Grid.Row="0">
                    <views:FilmstripView x:Name="FilmstripControl" />
                </ScrollViewer>
                <views:BatchPanelView Grid.Row="1" x:Name="BatchPanelControl" />
            </Grid>

            <!-- Left Splitter -->
            <GridSplitter Grid.Column="1" Width="4"
                          Background="Transparent"
                          ResizeDirection="Columns"
                          ResizeBehavior="BasedOnAlignment" />

            <!-- Center Panel: Preview + Mini DAG -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="2*" />
                </Grid.RowDefinitions>

                <views:PreviewView Grid.Row="0" x:Name="PreviewControl" />
                <GridSplitter Grid.Row="1" Height="4"
                              Background="Transparent"
                              ResizeDirection="Rows"
                              ResizeBehavior="BasedOnAlignment" />
                <views:PipelineEditorView Grid.Row="2" x:Name="PipelineEditorControl" />
            </Grid>

            <!-- Right Splitter -->
            <GridSplitter Grid.Column="3" Width="4"
                          Background="Transparent"
                          ResizeDirection="Columns"
                          ResizeBehavior="BasedOnAlignment" />

            <!-- Right Panel: Plugin Controls -->
            <ScrollViewer Grid.Column="4"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <views:PluginPanelView x:Name="PluginPanelControl" />
            </ScrollViewer>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Height="24"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="StatusText" Text="Ready"
                           VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Grid.Column="2" x:Name="ZoomText" Text="100%"
                           VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Grid>
        </Border>
    </Grid>
</Window>
