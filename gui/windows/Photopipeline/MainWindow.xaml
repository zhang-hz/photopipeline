<Window x:Class="Photopipeline.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:views="clr-namespace:Photopipeline.Views"
             mc:Ignorable="d"
             Title="{Binding WindowTitle}"
             Width="{Binding WindowWidth}" Height="{Binding WindowHeight}"
             MinWidth="960" MinHeight="600"
             WindowStartupLocation="CenterScreen"
             d:DataContext="{d:DesignInstance Type=ViewModels.MainViewModel}">

    <Window.InputBindings>
        <KeyBinding Key="OemPlus" Modifiers="Ctrl" Command="{Binding ZoomInCommand}" />
        <KeyBinding Key="OemMinus" Modifiers="Ctrl" Command="{Binding ZoomOutCommand}" />
        <KeyBinding Key="D0" Modifiers="Ctrl" Command="{Binding ResetZoomCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="2*" MinWidth="300" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="360" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <!-- Filmstrip Panel -->
            <Border Grid.Column="0" Background="{DynamicResource ControlFillColorDefaultBrush}">
                <views:FilmstripView DataContext="{Binding Filmstrip}" />
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="{DynamicResource DividerStrokeColorDefaultBrush}" />

            <!-- Preview Panel -->
            <Border Grid.Column="2" Background="{DynamicResource SolidBackgroundFillColorBaseBrush}">
                <views:PreviewView DataContext="{Binding Preview}" />
            </Border>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch"
                          Background="{DynamicResource DividerStrokeColorDefaultBrush}" />

            <!-- Right Panel: Tools + Plugin Browser -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*" />
                    <RowDefinition Height="4" />
                    <RowDefinition Height="2*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource ControlFillColorDefaultBrush}">
                    <TabControl Background="{DynamicResource ApplicationBackgroundBrush}">
                        <TabItem Header="Pipeline">
                            <views:PipelineEditorView DataContext="{Binding PipelineEditor}" />
                        </TabItem>
                        <TabItem Header="Batch">
                            <views:BatchView DataContext="{Binding Batch}" />
                        </TabItem>
                        <TabItem Header="Settings">
                            <StackPanel Margin="12">
                                <TextBlock Text="Settings" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />

                                <TextBlock Text="Theme" FontSize="11" Margin="0,0,0,2"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <ComboBox ItemsSource="{Binding Settings.Themes}"
                                          SelectedItem="{Binding Settings.Theme}"
                                          FontSize="12" Margin="0,0,0,10" />

                                <TextBlock Text="Default Output Format" FontSize="11" Margin="0,0,0,2"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <ComboBox ItemsSource="{Binding Settings.OutputFormats}"
                                          SelectedItem="{Binding Settings.DefaultOutputFormat}"
                                          FontSize="12" Margin="0,0,0,10" />

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBackendHealthy}" Value="False">
                                                        <Setter Property="Fill" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock FontSize="11" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                        <Run Text="Backend: " />
                                        <Run Text="{Binding BackendStatus, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>

                                <ui:Button Content="Advanced Settings..." Command="{Binding ShowSettingsCommand}"
                                           Appearance="Secondary" HorizontalAlignment="Left" FontSize="12" />
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </Border>

                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch"
                              Background="{DynamicResource DividerStrokeColorDefaultBrush}" />

                <Border Grid.Row="2" Background="{DynamicResource ControlFillColorDefaultBrush}">
                    <views:PluginBrowserView DataContext="{Binding PluginBrowser}" />
                </Border>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="1" Background="{DynamicResource ControlFillColorSecondaryBrush}"
                Padding="8,4" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                <TextBlock Grid.Column="2" FontSize="12" Margin="16,0,0,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                    <Run Text="Backend:" />
                    <Run Text="{Binding BackendStatus, Mode=OneWay}" />
                </TextBlock>

                <Ellipse Grid.Column="3" Width="8" Height="8" Margin="6,0,0,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBackendHealthy}" Value="False">
                                    <Setter Property="Fill" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
            </Grid>
        </Border>
    </Grid>
</Window>
