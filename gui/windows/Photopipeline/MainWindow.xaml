<ui:FluentWindow x:Class="Photopipeline.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:views="clr-namespace:Photopipeline.Views"
    mc:Ignorable="d"
    Title="{Binding WindowTitle}"
    Width="{Binding WindowWidth}" Height="{Binding WindowHeight}"
    MinWidth="1100" MinHeight="650"
    WindowStartupLocation="CenterScreen"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    d:DataContext="{d:DesignInstance Type=ViewModels.MainViewModel}">

    <ui:FluentWindow.InputBindings>
        <KeyBinding Key="OemPlus" Modifiers="Ctrl" Command="{Binding ZoomInCommand}" />
        <KeyBinding Key="OemMinus" Modifiers="Ctrl" Command="{Binding ZoomOutCommand}" />
        <KeyBinding Key="D0" Modifiers="Ctrl" Command="{Binding ResetZoomCommand}" />
    </ui:FluentWindow.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- TitleBar -->
        <ui:TitleBar
            x:Name="TitleBar"
            Grid.Row="0"
            Title="Photopipeline"
            CloseWindowByDoubleClickOnIcon="True">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Image24" Filled="True" />
            </ui:TitleBar.Icon>
            <ui:TitleBar.TrailingContent>
                <StackPanel Orientation="Horizontal">
                    <ui:Button x:Name="ThemeToggleBtn" Icon="{ui:SymbolIcon WeatherSunny24}"
                        Appearance="Transparent" ToolTip="Toggle theme" Click="OnThemeToggleClick" Margin="0,0,4,0" />
                    <ui:Button Icon="{ui:SymbolIcon Settings24}"
                        Appearance="Transparent" ToolTip="Settings"
                        Command="{Binding ShowSettingsCommand}" />
                </StackPanel>
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <!-- Main Content: 3 columns -->
        <Grid Grid.Row="1" Margin="4,2,0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="2*" MinWidth="300" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="380" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <!-- Left: Filmstrip (top) + Plugin Browser (bottom) -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*" MinHeight="200" />
                    <RowDefinition Height="4" />
                    <RowDefinition Height="2*" MinHeight="150" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="6" Margin="2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,8,6,4">
                            <ui:SymbolIcon Symbol="ImageMultiple24" Margin="0,0,6,0" />
                            <TextBlock Text="Filmstrip" FontSize="13" FontWeight="SemiBold" />
                        </StackPanel>
                        <views:FilmstripView Grid.Row="1" DataContext="{Binding Filmstrip}" />
                    </Grid>
                </Border>

                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch"
                    Background="{DynamicResource DividerStrokeColorDefaultBrush}" />

                <Border Grid.Row="2" Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="6" Margin="2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,8,6,4">
                            <ui:SymbolIcon Symbol="AppsAddIn24" Margin="0,0,6,0" />
                            <TextBlock Text="Plugins" FontSize="13" FontWeight="SemiBold" />
                        </StackPanel>
                        <views:PluginBrowserView Grid.Row="1" DataContext="{Binding PluginBrowser}" />
                    </Grid>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                Background="{DynamicResource DividerStrokeColorDefaultBrush}" />

            <!-- Center: Preview -->
            <Border Grid.Column="2" Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                CornerRadius="6" Margin="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,8,6,4">
                        <ui:SymbolIcon Symbol="Eye24" Margin="0,0,6,0" />
                        <TextBlock Text="Preview" FontSize="13" FontWeight="SemiBold" />
                    </StackPanel>
                    <views:PreviewView Grid.Row="1" DataContext="{Binding Preview}" />
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch"
                Background="{DynamicResource DividerStrokeColorDefaultBrush}" />

            <!-- Right: Pipeline Editor (top) + Batch (bottom) -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*" MinHeight="250" />
                    <RowDefinition Height="4" />
                    <RowDefinition Height="2*" MinHeight="150" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="6" Margin="2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,8,6,4">
                            <ui:SymbolIcon Symbol="Flowchart24" Margin="0,0,6,0" />
                            <TextBlock Text="Pipeline Editor" FontSize="13" FontWeight="SemiBold" />
                            <TextBlock FontSize="10" Margin="8,0,0,0"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center">
                                <Run Text="(" />
                                <Run Text="{Binding PipelineEditor.IsPipelineValid, Mode=OneWay, StringFormat=Valid: {0}}" />
                                <Run Text=")" />
                            </TextBlock>
                        </StackPanel>
                        <views:PipelineEditorView Grid.Row="1" DataContext="{Binding PipelineEditor}" />
                    </Grid>
                </Border>

                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch"
                    Background="{DynamicResource DividerStrokeColorDefaultBrush}" />

                <Border Grid.Row="2" Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="6" Margin="2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,8,6,4">
                            <ui:SymbolIcon Symbol="ArrowSyncCircle24" Margin="0,0,6,0" />
                            <TextBlock Text="Batch Processing" FontSize="13" FontWeight="SemiBold" />
                        </StackPanel>
                        <views:BatchView Grid.Row="1" DataContext="{Binding Batch}" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Status Bar + Snackbar -->
        <Border Grid.Row="2" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            Padding="10,6" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="12"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />

                <ui:SnackbarPresenter Grid.Column="1" x:Name="SnackbarPresenter"
                    Margin="8,0" VerticalAlignment="Center" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBackendHealthy}" Value="False">
                                        <Setter Property="Fill" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock FontSize="12" VerticalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                        <Run Text="Backend:" />
                        <Run Text="{Binding BackendStatus, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
