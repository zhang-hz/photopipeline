<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Photopipeline.Controls.BeforeAfterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootLayout">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="BeforeColumn" Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition x:Name="AfterColumn" Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" x:Name="BeforePanel">
            <Border Background="#F0F0F0">
                <Image x:Name="BeforeImage"
                       Source="{x:Null}"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
            </Border>
            <Border Background="#66000000" VerticalAlignment="Bottom"
                    HorizontalAlignment="Left" CornerRadius="0,4,0,0"
                    Padding="8,3" Margin="0">
                <TextBlock Text="BEFORE"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="White" />
            </Border>
        </Grid>

        <Grid Grid.Column="1" x:Name="SplitHandle" Width="4"
              HorizontalAlignment="Center"
              MouseLeftButtonDown="OnSplitHandleMouseDown"
              MouseMove="OnSplitHandleMouseMove"
              MouseLeftButtonUp="OnSplitHandleMouseUp"
              Cursor="SizeWE">
            <Border Background="#33000000" />

            <Border Width="4" Height="40"
                    Background="White"
                    CornerRadius="2"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" Opacity="0.3" BlurRadius="6" />
                </Border.Effect>
            </Border>

            <TextBlock Text="&#xE8AB;"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="10"
                       Foreground="#666"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Grid>

        <Grid Grid.Column="2" x:Name="AfterPanel">
            <Border Background="#F0F0F0">
                <Image x:Name="AfterImage"
                       Source="{x:Null}"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
            </Border>
            <Border Background="#66000000" VerticalAlignment="Bottom"
                    HorizontalAlignment="Right" CornerRadius="4,0,0,0"
                    Padding="8,3" Margin="0">
                <TextBlock Text="AFTER"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="White" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
