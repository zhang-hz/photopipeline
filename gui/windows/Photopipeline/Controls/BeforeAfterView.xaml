<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Photopipeline.Controls.BeforeAfterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootLayout">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="BeforeColumn" Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition x:Name="AfterColumn" Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Before Image -->
        <Grid Grid.Column="0" x:Name="BeforePanel">
            <Border Background="{ThemeResource LayerFillColorDefaultBrush}">
                <Image x:Name="BeforeImage"
                       Source="{x:Null}"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
            </Border>
            <Border Background="#66000000" VerticalAlignment="Bottom"
                    HorizontalAlignment="Left" CornerRadius="0,4,0,0"
                    Padding="8,3" Margin="0">
                <TextBlock Text="BEFORE"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="White" />
            </Border>
        </Grid>

        <!-- Split Handle -->
        <Grid Grid.Column="1" x:Name="SplitHandle" Width="4"
              ManipulationMode="TranslateX"
              ManipulationDelta="OnSplitHandleDrag"
              HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.ColumnSpan="3" Background="#33000000" />

            <Border Grid.Column="1"
                    Width="4" Height="40"
                    Background="White"
                    CornerRadius="2"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Shadow="{ThemeResource SharedShadow}" />

            <StackPanel Grid.Column="1" HorizontalAlignment="Center"
                        VerticalAlignment="Center" Spacing="4">
                <SymbolIcon Symbol="Switch" Width="12" Height="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <!-- After Image -->
        <Grid Grid.Column="2" x:Name="AfterPanel">
            <Border Background="{ThemeResource LayerFillColorDefaultBrush}">
                <Image x:Name="AfterImage"
                       Source="{x:Null}"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
            </Border>
            <Border Background="#66000000" VerticalAlignment="Bottom"
                    HorizontalAlignment="Right" CornerRadius="4,0,0,0"
                    Padding="8,3" Margin="0">
                <TextBlock Text="AFTER"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="White" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
