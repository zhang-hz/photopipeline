<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Photopipeline.Controls.NodeControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Photopipeline.Models"
    mc:Ignorable="d"
    Width="160" Height="80">

    <Grid>
        <Border x:Name="NodeBorder"
                CornerRadius="8"
                BorderThickness="1.5"
                Background="#282C34"
                BorderBrush="#50545C"
                PointerPressed="OnNodePointerPressed"
                PointerMoved="OnNodePointerMoved"
                PointerReleased="OnNodePointerReleased"
                RightTapped="OnNodeRightTapped">
            <Grid RowSpacing="2" Margin="10,6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           x:Name="NodeTitleText"
                           Text="Plugin Name"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#DCDCE1"
                           TextTrimming="CharacterEllipsis" />

                <TextBlock Grid.Row="1"
                           x:Name="NodeCategoryText"
                           Text="Category"
                           FontSize="9"
                           Foreground="#94A3B8"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Top"
                           Margin="0,1,0,0" />
            </Grid>
        </Border>

        <Border x:Name="InputPortDot"
                Width="10" Height="10"
                CornerRadius="5"
                Background="#96AAC8"
                BorderThickness="1"
                BorderBrush="White"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Margin="-5,0,0,0" />

        <Border x:Name="OutputPortDot"
                Width="10" Height="10"
                CornerRadius="5"
                Background="#96AAC8"
                BorderThickness="1"
                BorderBrush="White"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="0,0,-5,0" />
    </Grid>
</UserControl>
